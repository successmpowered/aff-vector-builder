    "dex_v2_matcher/MatchProof": {
      "title": "MatchProof",
      "description": "============================================================================\n DEX V2: PERMISSIONLESS MATCHER / ANTI-MEV SCOOP ENGINE\n ============================================================================\n\n The KEY innovation that eliminates centralized batchers:\n\n 1. PRICE ON-CHAIN: Each order's min_receive is in the order datum.\n    The scooper cannot give less. They can give MORE (price improvement).\n\n 2. FLAT FEE: Scooper earns a fixed fee per order, NOT percentage.\n    This removes incentive to manipulate prices for bigger trades.\n\n 3. PERMISSIONLESS: Anyone can scoop. No registration, no staking.\n    Competition between scoopers drives fees to minimum.\n\n 4. DETERMINISTIC: UTXO model means the tx outcome is known at build time.\n    No front-running possible — attacker invalidates victim's tx inputs.\n\n This validator manages the matcher's bond and batch settlement.",
      "anyOf": [
        {
          "title": "MatchProof",
          "dataType": "constructor",
          "index": 0,
          "fields": [
            {
              "title": "order_a_ref",
              "$ref": "#/definitions/ByteArray"
            },
            {
              "title": "order_b_ref",
              "$ref": "#/definitions/ByteArray"
            },
            {
              "title": "price_num",
              "$ref": "#/definitions/Int"
            },
            {
              "title": "price_den",
              "$ref": "#/definitions/Int"
            },
            {
              "title": "amount_a",
              "$ref": "#/definitions/Int"
            },
            {
              "title": "amount_b",
              "$ref": "#/definitions/Int"
            }
          ]
        }
      ]
    }
